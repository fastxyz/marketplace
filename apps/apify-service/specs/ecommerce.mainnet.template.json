  "endpoints": [
    {
      "endpointType": "marketplace_proxy",
      "operation": "scrape-products",
      "title": "Scrape Products",
      "description": "Extract product and pricing data from retail sites using product URLs, category URLs, or search terms.",
      "billingType": "fixed_x402",
      "price": "$0.0001",
      "method": "POST",
      "mode": "async",
      "asyncStrategy": "poll",
      "asyncTimeoutMs": 1800000,
      "pollPath": "/runs/poll",
      "requestSchemaJson": {
        "type": "object",
        "properties": {
          "startUrls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "url"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "additionalProperties": false
            }
          },
          "search": {
            "type": "string",
            "minLength": 1
          },
          "country": {
            "type": "string",
            "minLength": 2
          },
          "maxItems": {
            "type": "integer",
            "minimum": 1
          }
        },
        "anyOf": [
          {
            "required": [
              "startUrls"
            ]
          },
          {
            "required": [
              "search"
            ]
          }
        ],
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "startUrls": [
          {
            "url": "https://www.amazon.com/dp/B09X7MPX8L"
          }
        ],
        "country": "US",
        "maxItems": 10
      },
      "responseExample": {
        "runId": "apify_run_123",
        "status": "SUCCEEDED",
        "items": [
          {
            "title": "Example Product",
            "price": {
              "value": 49.99,
              "currency": "$"
            },
            "url": "https://example.com/product"
          }
        ]
      },
      "usageNotes": "Use this for multi-site product intelligence when you do not want a site-specific scraper per merchant.",
      "upstreamBaseUrl": "https://fastmainnetapifyecommerce.8o.vc",
      "upstreamPath": "/scrape-products",
      "upstreamAuthMode": "none"
    },
