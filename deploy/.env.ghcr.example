# Copy to deploy/.env.ghcr and fill in deploy-time values before running docker compose.
# Keep this file in git. Keep the real deploy/.env.ghcr out of git.
#
# Add these secrets manually in your VPS env file or deployment platform secret store:
# - POSTGRES_PASSWORD
# - MARKETPLACE_SESSION_SECRET
# - MARKETPLACE_ADMIN_TOKEN
# - MARKETPLACE_SECRETS_KEY
# - MARKETPLACE_TREASURY_PRIVATE_KEY or MARKETPLACE_TREASURY_KEYFILE
#
# These values are normal non-secret deploy config:
# - API_IMAGE
# - WEB_IMAGE
# - WORKER_IMAGE
# - FACILITATOR_IMAGE
# - MARKETPLACE_FAST_NETWORK
# - MARKETPLACE_BASE_URL
# - MARKETPLACE_WEB_BASE_URL
# - MARKETPLACE_API_BASE_URL
# - NEXT_PUBLIC_MARKETPLACE_API_BASE_URL
# - FAST_RPC_URL
# - FACILITATOR_FAST_RPC_URL
# - API_PORT
# - WEB_PORT
# - WORKER_POLL_INTERVAL_MS

API_IMAGE=ghcr.io/example-owner/ai-agent-marketplace-api:latest
WEB_IMAGE=ghcr.io/example-owner/ai-agent-marketplace-web:latest
WORKER_IMAGE=ghcr.io/example-owner/ai-agent-marketplace-worker:latest
FACILITATOR_IMAGE=ghcr.io/example-owner/ai-agent-marketplace-facilitator:latest

POSTGRES_DB=fast_marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password

MARKETPLACE_TREASURY_ADDRESS=fast1replace_me
MARKETPLACE_SESSION_SECRET=replace-with-long-random-session-secret
MARKETPLACE_ADMIN_TOKEN=replace-with-long-random-admin-token
MARKETPLACE_SECRETS_KEY=replace-with-long-random-secrets-key
MARKETPLACE_FAST_NETWORK=mainnet
MARKETPLACE_BASE_URL=https://api.marketplace.example.com
MARKETPLACE_WEB_BASE_URL=https://marketplace.example.com
MARKETPLACE_API_BASE_URL=https://api.marketplace.example.com
NEXT_PUBLIC_MARKETPLACE_API_BASE_URL=https://api.marketplace.example.com

FAST_RPC_URL=https://api.fast.xyz/proxy
FACILITATOR_FAST_RPC_URL=https://api.fast.xyz/proxy

# Choose one. Prefer MARKETPLACE_TREASURY_KEYFILE when your platform supports mounted secret files.
MARKETPLACE_TREASURY_PRIVATE_KEY=
MARKETPLACE_TREASURY_KEYFILE=

API_PORT=3000
WEB_PORT=3001
WORKER_POLL_INTERVAL_MS=5000
